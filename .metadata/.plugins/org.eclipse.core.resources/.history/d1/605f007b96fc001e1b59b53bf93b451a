#include "stm32f4xx.h"
#include <stdint.h>

void delay (uint32_t time){
	for (int i=0;i<time;i++)
		for(int j=0; j<time; j++);
}

int main(void)
{
	SET_BIT(RCC->AHB1ENR,RCC_AHB1ENR_GPIOAEN); //enable the clock for port A
	MODIFY_REG(GPIOA->MODER,GPIO_MODER_MODER5,(1U<<GPIO_MODER_MODER5_Pos)); //enable the pin 5 in output mode
	MODIFY_REG(GPIOA->MODER,GPIO_MODER_MODER0,(0U<<GPIO_MODER_MODER0_Pos)); //enabling the pin 0 in input mode

	while(1){

	SET_BIT(GPIOA->IDR,GPIO_IDR_IDR_0); //enable the PA0 in input mode

	if(READ_BIT(GPIOA->IDR,GPIO_IDR_IDR_0)){

		//if PA0 is in high level (Vdd), then turn on led
		SET_BIT(GPIOA->ODR,GPIO_ODR_ODR_5);

	}
	else CLEAR_BIT(GPIOA->ODR,GPIO_ODR_ODR_5);

	}
}
